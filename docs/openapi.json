{
  "openapi": "3.1.0",
  "info": {
    "title": "PR Insight API",
    "description": "우테코 미션 PR 리뷰 코멘트를 자연어로 검색하고, 비슷한 의도의 답변끼리 그룹화하여 요약(2-3문장)과 PR 원문 링크를 함께 제공하는 API.",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "system"
        ],
        "summary": "헬스 체크",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/search": {
      "get": {
        "tags": [
          "search"
        ],
        "summary": "리뷰 코멘트 검색 (답변 방향성 그룹화)",
        "description": "자연어 query로 conversation document를 검색한 뒤 공식 리뷰어의 개별 답변을 추출하고, 비슷한 방향성의 답변끼리 그룹화한다. 각 그룹(items[])은 화면 인사이트 카드 한 장에 대응하며, 대표 요약과 개별 GitHub comment 아웃링크를 포함한다.",
        "operationId": "search_api_search_get",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "description": "검색할 자연어 질문",
              "examples": [
                "500에러 예외처리시 응답 구조"
              ],
              "title": "Query"
            },
            "description": "검색할 자연어 질문"
          },
          {
            "name": "track",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "트랙 필터",
              "examples": [
                "BACKEND"
              ],
              "title": "Track"
            },
            "description": "트랙 필터"
          },
          {
            "name": "mission",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "미션 이름 필터",
              "examples": [
                "roomescape"
              ],
              "title": "Mission"
            },
            "description": "미션 이름 필터"
          },
          {
            "name": "repository",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "레포지토리 풀네임 필터",
              "examples": [
                "woowacourse/spring-roomescape-member"
              ],
              "title": "Repository"
            },
            "description": "레포지토리 풀네임 필터"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "그룹화에 사용할 최대 리뷰어 답변 코멘트 수",
              "default": 30,
              "title": "Limit"
            },
            "description": "그룹화에 사용할 최대 리뷰어 답변 코멘트 수"
          },
          {
            "name": "summarize",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "description": "true면 GPT로 그룹 제목/요약 생성, false면 대표 snippet 사용",
              "default": true,
              "title": "Summarize"
            },
            "description": "true면 GPT로 그룹 제목/요약 생성, false면 대표 snippet 사용"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/conversations/{conversation_id}": {
      "get": {
        "tags": [
          "conversations"
        ],
        "summary": "대화 상세 조회",
        "description": "그룹 카드 클릭 시 호출한다. conversation document에 묶인 원본 리뷰 코멘트들을 시간순(CONTEXT → REPLY)으로 반환하며, 각 코멘트는 GitHub 원문 링크를 포함한다.",
        "operationId": "get_conversation_api_conversations__conversation_id__get",
        "parameters": [
          {
            "name": "conversation_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Conversation Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConversationDetail"
                }
              }
            }
          },
          "404": {
            "description": "해당 conversation을 찾을 수 없음",
            "content": {
              "application/json": {
                "example": {
                  "detail": "Conversation not found"
                },
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/tracks": {
      "get": {
        "tags": [
          "filters"
        ],
        "summary": "트랙 목록 조회",
        "description": "검색 필터 UI에 노출할 트랙 목록과 각 트랙의 문서 수를 반환한다.",
        "operationId": "list_tracks_api_tracks_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/TrackOption"
                  },
                  "type": "array",
                  "title": "Response List Tracks Api Tracks Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/missions": {
      "get": {
        "tags": [
          "filters"
        ],
        "summary": "미션 목록 조회",
        "description": "검색 필터 UI에 노출할 미션 목록을 반환한다. track으로 필터링할 수 있다.",
        "operationId": "list_missions_api_missions_get",
        "parameters": [
          {
            "name": "track",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "특정 트랙의 미션만 조회",
              "examples": [
                "BACKEND"
              ],
              "title": "Track"
            },
            "description": "특정 트랙의 미션만 조회"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MissionOption"
                  },
                  "title": "Response List Missions Api Missions Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
